meta {
  name: Criar Advogado
  type: http
  seq: 2
}

post {
  url: {{base_url}}/lawyer/create
  body: json
  auth: none
}

headers {
  X-API-KEY: {{api_key}}
  Content-Type: application/json
}

body:json {
  {
    "full_name": "Maria Santos",
    "oab_number": "789012",
    "oab_id": "SP_789012",
    "state": "SP",
    "city": "São Paulo",
    "address": "Rua das Flores, 456",
    "original_address": "Rua das Flores, 456 - Centro",
    "zip_code": "01234-567",
    "phone_number_1": "(11) 99999-8888",
    "phone_number_2": "(11) 3333-4444",
    "phone_1_has_whatsapp": true,
    "phone_2_has_whatsapp": false,
    "profession": "Advogado",
    "situation": "Regular",
    "suplementary": false,
    "is_procstudio": false,
    "specialty": "Direito Civil",
    "bio": "Advogada especializada em direito civil e família",
